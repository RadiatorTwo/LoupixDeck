<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:LoupixDeck.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="clr-namespace:LoupixDeck.Models.Converter"
             xmlns:utils="clr-namespace:LoupixDeck.Utils"
             mc:Ignorable="d"
             x:Class="LoupixDeck.Views.Devices.LoupedeckLiveSLayout"
             x:DataType="vm:MainWindowViewModel"
             x:Name="RootControl">
    <UserControl.Styles>
        <!-- RGB LED buttons: the colour/glow is baked into the rendered image. A bare
             template (no chrome border/background) guarantees no grey box ever appears
             in any state — hover, press, focus, or while a modal dialog disables the
             window. The only feedback is a subtle forward (scale) movement. -->
        <Style Selector="Button.Led">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Led:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.06)" />
        </Style>
        <Style Selector="Button.Led:pressed">
            <Setter Property="RenderTransform" Value="scale(0.94)" />
        </Style>

        <!-- Rotary dials: the realistic knob is baked into the rendered image. Like
             the LED buttons, a bare template guarantees no grey box appears in any
             state; the only feedback is a subtle scale movement. -->
        <Style Selector="Button.Dial">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Dial:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.04)" />
        </Style>
        <Style Selector="Button.Dial:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)" />
        </Style>

        <!-- Touch buttons: chrome-free so only the rendered image shows, with the
             dark bezel behind it filling the gaps and rounded corners. No grey
             button background in any state (hover, press, focus, dialog). -->
        <Style Selector="Button[Tag=Touch]">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="RenderTransformOrigin" Value="50%,50%" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                </ControlTemplate>
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08" />
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button[Tag=Touch]:pointerover">
            <!-- Lift above neighbours so the centred forward zoom is never clipped. -->
            <Setter Property="ZIndex" Value="1" />
            <Setter Property="RenderTransform" Value="scale(1.05)" />
        </Style>
        <Style Selector="Button[Tag=Touch]:pressed">
            <Setter Property="RenderTransform" Value="scale(0.96)" />
        </Style>
    </UserControl.Styles>

    <Grid ColumnDefinitions="Auto,522,Auto" RowDefinitions="Auto,Auto,16">

        <!-- Rotary page controls as their own strip above the device (left, over the
             dials), separated from the device buttons so the dials stay flush with
             the touch buttons instead of being pushed down. The touch pager lives
             below its own screen (further down). -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Classes="Pager"
                HorizontalAlignment="Left" Margin="12,6,12,12">
            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Button Classes="PagerBtn PagerNav" Content="‹"
                        ToolTip.Tip="Vorherige Rotary-Seite"
                        Command="{Binding PreviousRotaryPageCommand}" />
                <TextBox Classes="PageName" Width="160"
                         Text="{Binding LoupedeckController.Config.CurrentRotaryButtonPage.Name, Mode=TwoWay}"
                         Watermark="{Binding LoupedeckController.Config.CurrentRotaryButtonPage.PageName}"
                         KeyDown="OnPageNameKeyDown" LostFocus="OnPageNameCommit" />
                <Button Classes="PagerBtn PagerNav" Content="›"
                        ToolTip.Tip="Nächste Rotary-Seite"
                        Command="{Binding NextRotaryPageCommand}" />
                <TextBlock Classes="PageCount"
                           Text="{Binding LoupedeckController.Config.RotaryPageLabel}"
                           ToolTip.Tip="Aktuelle / Anzahl Rotary-Seiten" />
                <Button Classes="PagerBtn" Content="+"
                        ToolTip.Tip="Rotary-Seite hinzufügen"
                        Command="{Binding AddRotaryPageCommand}" />
                <Button Classes="PagerBtn delete" Content="✕"
                        ToolTip.Tip="Aktuelle Rotary-Seite löschen"
                        Command="{Binding DeleteRotaryPageCommand}" />
            </StackPanel>
        </Border>

        <!-- Rotary dials (7 mm apart) with the first LED button 10 mm below. -->
        <StackPanel Grid.Row="1" Grid.Column="0"
                    Orientation="Vertical" HorizontalAlignment="Center"
                    VerticalAlignment="Top" Margin="12,0,30,0">
            <Button Classes="Dial"
                HorizontalAlignment="Center"
                Width="90"
                Height="90"
                Command="{Binding RotaryButtonCommand}"
                CommandParameter="{Binding LoupedeckController.Config.CurrentRotaryButtonPage.RotaryButtons[0], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <Image Source="{x:Static utils:BitmapHelper.RotaryKnobImage}"
                       Width="90" Height="90" />
            </Button>
            <Button Classes="Dial"
                Margin="0,42,0,0"
                HorizontalAlignment="Center"
                Width="90"
                Height="90"
                Command="{Binding RotaryButtonCommand}"
                CommandParameter="{Binding LoupedeckController.Config.CurrentRotaryButtonPage.RotaryButtons[1], Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <Image Source="{x:Static utils:BitmapHelper.RotaryKnobImage}"
                       Width="90" Height="90" />
            </Button>
            <Button Tag="Led" Classes="Led"
                    Margin="0,72,0,0"
                    HorizontalAlignment="Center"
                    Width="66"
                    Height="66"
                    Command="{Binding SimpleButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.SimpleButtons[0]}">
                <Border Background="Transparent" Width="66" Height="66" CornerRadius="33">
                    <Image Source="{Binding LoupedeckController.Config.SimpleButtons[0].RenderedImage}" />
                </Border>
            </Button>
        </StackPanel>

        <!-- Touch-screen bezel: dark frame around and between the touch buttons,
             matching the real device (6 mm L/R, 3 mm top/bottom, 2 mm gaps at
             6 px/mm; corners slightly rounder than the buttons). -->
        <StackPanel Grid.Row="1" Grid.Column="1"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,9,0,0" Spacing="6">
        <Border HorizontalAlignment="Center"
                Background="#121212" CornerRadius="12" Padding="36,18">
        <!-- Rounded, clipping wrapper so the continuous wallpaper keeps rounded outer
             corners. The buttons sit gapless (so the wallpaper runs seamlessly across,
             matching the real device's continuous display); the dark frame between
             buttons is painted ON TOP as an overlay (see below). -->
        <Border CornerRadius="8" ClipToBounds="True">
        <Grid>
        <Grid ColumnDefinitions="90,90,90,90,90" RowDefinitions="90,90,90">
            <Button Tag="Touch" Grid.Row="0" Grid.Column="0" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[0]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[0].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="0" Grid.Column="1" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[1]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[1].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="0" Grid.Column="2" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[2]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[2].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="0" Grid.Column="3" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[3]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[3].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="0" Grid.Column="4" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[4]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[4].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>

            <Button Tag="Touch" Grid.Row="1" Grid.Column="0" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[5]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[5].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="1" Grid.Column="1" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[6]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[6].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="1" Grid.Column="2" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[7]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[7].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="1" Grid.Column="3" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[8]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[8].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="1" Grid.Column="4" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[9]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[9].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>

            <Button Tag="Touch" Grid.Row="2" Grid.Column="0" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[10]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[10].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="2" Grid.Column="1" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[11]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[11].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="2" Grid.Column="2" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[12]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[12].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="2" Grid.Column="3" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[13]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[13].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
            <Button Tag="Touch" Grid.Row="2" Grid.Column="4" Width="90" Height="90"
                    Command="{Binding TouchButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[14]}">
                <Border CornerRadius="0" ClipToBounds="True">
                    <Image Source="{Binding LoupedeckController.Config.CurrentTouchButtonPage.TouchButtons[14].RenderedImage, Converter={StaticResource SkiaToBitmapConverter}}" />
                </Border>
            </Button>
        </Grid>
        <!-- Frame overlay drawn ON TOP of the gapless buttons: a solid dark panel with
             one rounded-rectangle hole per button (EvenOdd punches the holes out of the
             outer 450x270 rect). The wallpaper underneath stays continuous; the holes
             give each button rounded corners again. Frame is 4.5 px (0.75 mm at 6 px/mm)
             per edge to match the real device: the 9 px bands between holes form the
             seams, the 4.5 px outer edge meets the bezel padding.
             IsHitTestVisible=False so clicks pass through. -->
        <Path Fill="#121212" Opacity="0.85" IsHitTestVisible="False"
              HorizontalAlignment="Left" VerticalAlignment="Top">
            <Path.Data>
                <GeometryGroup FillRule="EvenOdd">
                    <RectangleGeometry Rect="0,0,450,270" />
                    <RectangleGeometry Rect="4.5,4.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="94.5,4.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="184.5,4.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="274.5,4.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="364.5,4.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="4.5,94.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="94.5,94.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="184.5,94.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="274.5,94.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="364.5,94.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="4.5,184.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="94.5,184.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="184.5,184.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="274.5,184.5,81,81" RadiusX="6" RadiusY="6" />
                    <RectangleGeometry Rect="364.5,184.5,81,81" RadiusX="6" RadiusY="6" />
                </GeometryGroup>
            </Path.Data>
        </Path>
        </Grid>
        </Border>
        </Border>

            <!-- Touch page pager, centred below the touch screen it controls. -->
            <Border Classes="Pager" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Classes="PagerBtn PagerNav" Content="‹"
                            ToolTip.Tip="Vorherige Touch-Seite"
                            Command="{Binding PreviousTouchPageCommand}" />
                    <TextBox Classes="PageName"
                             Text="{Binding LoupedeckController.Config.CurrentTouchButtonPage.Name, Mode=TwoWay}"
                             Watermark="{Binding LoupedeckController.Config.CurrentTouchButtonPage.PageName}"
                             KeyDown="OnPageNameKeyDown" LostFocus="OnPageNameCommit" />
                    <Button Classes="PagerBtn PagerNav" Content="›"
                            ToolTip.Tip="Nächste Touch-Seite"
                            Command="{Binding NextTouchPageCommand}" />
                    <TextBlock Classes="PageCount"
                               Text="{Binding LoupedeckController.Config.TouchPageLabel}"
                               ToolTip.Tip="Aktuelle / Anzahl Touch-Seiten" />
                    <Button Classes="PagerBtn" Content="+"
                            ToolTip.Tip="Touch-Seite hinzufügen"
                            Command="{Binding AddTouchPageCommand}" />
                    <Button Classes="PagerBtn delete" Content="✕"
                            ToolTip.Tip="Aktuelle Touch-Seite löschen"
                            Command="{Binding DeleteTouchPageCommand}" />
                </StackPanel>
            </Border>

        </StackPanel>

        <!-- Right LED buttons: 7 mm from the touch bezel, 12 mm apart vertically.
             The trailing right margin leaves room for the hover scale so the
             buttons are not clipped by the (SizeToContent) window edge. -->
        <StackPanel Grid.Row="1" Grid.Column="2"
                    Orientation="Vertical"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="42,15,12,0"
                    Spacing="72">
            <Button Tag="Led" Classes="Led" Width="66" Height="66"
                    Command="{Binding SimpleButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.SimpleButtons[1]}">
                <Border Background="Transparent" Width="66" Height="66" CornerRadius="33">
                    <Image Source="{Binding LoupedeckController.Config.SimpleButtons[1].RenderedImage}" />
                </Border>
            </Button>
            <Button Tag="Led" Classes="Led" Width="66" Height="66"
                    Command="{Binding SimpleButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.SimpleButtons[2]}">
                <Border Background="Transparent" Width="66" Height="66" CornerRadius="33">
                    <Image Source="{Binding LoupedeckController.Config.SimpleButtons[2].RenderedImage}" />
                </Border>
            </Button>
            <Button Tag="Led" Classes="Led" Width="66" Height="66"
                    Command="{Binding SimpleButtonCommand}"
                    CommandParameter="{Binding LoupedeckController.Config.SimpleButtons[3]}">
                <Border Background="Transparent" Width="66" Height="66" CornerRadius="33">
                    <Image Source="{Binding LoupedeckController.Config.SimpleButtons[3].RenderedImage}" />
                </Border>
            </Button>
        </StackPanel>

        <!-- Exclusive-mode overlay: while a provider owns the device, none of the
             on-screen controls reflect or affect it, so cover the whole device and
             swallow all input with a notice. -->
        <Border Grid.Row="1"
                Grid.Column="0" Grid.ColumnSpan="3"
                IsVisible="{Binding IsExclusiveModeActive}"
                Background="#E60F0F0F"
                BorderBrush="{StaticResource SelectedBrush}"
                BorderThickness="2"
                CornerRadius="6">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                <TextBlock Text="Exclusive Mode Active"
                           FontSize="22" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding ExclusiveModeTitle}"
                           FontSize="16" Foreground="#CCCCCC"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding ExclusiveModeTitle, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                <TextBlock Text="The device is being controlled. Its buttons are inactive."
                           FontSize="12" Foreground="#999999"
                           TextWrapping="Wrap" MaxWidth="420" TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
