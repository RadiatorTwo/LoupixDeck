<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LoupixDeck"
        xmlns:cnv="clr-namespace:LoupixDeck.Models.Converter"
        xmlns:vm="using:LoupixDeck.ViewModels"
        x:Class="LoupixDeck.Views.RotaryButtonSettings"
        x:DataType="vm:RotaryButtonSettingsViewModel"
        mc:Ignorable="d"
        Title="{Binding KnobLabel}"
        Width="1000"
        Height="700"
        SystemDecorations="Full"
        CanResize="False">

    <Window.Resources>
        <cnv:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Border.slot">
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="10" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceLow}" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style Selector="Border.slot.active">
            <Setter Property="BorderBrush" Value="#FF66AAFF" />
            <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
        </Style>
    </Window.Styles>

    <Border BorderThickness="2"
            BorderBrush="DarkGray"
            Padding="4">
        <Grid RowDefinitions="Auto,Auto,*" Margin="6">

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="{Binding KnobLabel}"
                       FontSize="22" FontWeight="Bold"
                       Margin="0,0,0,8" />

            <!-- OFF toggle sits directly under the title, above the command slots. -->
            <CheckBox Grid.Row="1"
                      Content="Run also when device is OFF"
                      IsChecked="{Binding ButtonData.EnableWhenOff}"
                      Margin="0,0,0,8" />

            <!-- Two columns: left = slot textboxes, right = command tree -->
            <Grid Grid.Row="2" ColumnDefinitions="*,420">

                <!-- Left: three slots -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <StackPanel>

                        <Border Classes="slot"
                                Classes.active="{Binding SelectedCommandSlot,
                                                 Converter={StaticResource EnumToBooleanConverter},
                                                 ConverterParameter=RotaryLeft}">
                            <StackPanel>
                                <TextBlock Text="Rotate Left" FontWeight="Bold" Margin="0,0,0,4" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             x:Name="TextBoxRotaryLeft"
                                             Text="{Binding ButtonData.RotaryLeftCommand}"
                                             GotFocus="TextBoxGotFocus" />
                                    <Button Grid.Column="1"
                                            Content="Clear"
                                            Tag="RotaryLeft"
                                            Width="70"
                                            Margin="6,0,0,0"
                                            Background="#A03030"
                                            Foreground="White"
                                            Click="ClearButton_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="slot"
                                Classes.active="{Binding SelectedCommandSlot,
                                                 Converter={StaticResource EnumToBooleanConverter},
                                                 ConverterParameter=RotaryRight}">
                            <StackPanel>
                                <TextBlock Text="Rotate Right" FontWeight="Bold" Margin="0,0,0,4" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             x:Name="TextBoxRotaryRight"
                                             Text="{Binding ButtonData.RotaryRightCommand}"
                                             GotFocus="TextBoxGotFocus" />
                                    <Button Grid.Column="1"
                                            Content="Clear"
                                            Tag="RotaryRight"
                                            Width="70"
                                            Margin="6,0,0,0"
                                            Background="#A03030"
                                            Foreground="White"
                                            Click="ClearButton_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Classes="slot"
                                Classes.active="{Binding SelectedCommandSlot,
                                                 Converter={StaticResource EnumToBooleanConverter},
                                                 ConverterParameter=ButtonPress}">
                            <StackPanel>
                                <TextBlock Text="Button Press" FontWeight="Bold" Margin="0,0,0,4" />
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBox Grid.Column="0"
                                             x:Name="TextBoxButtonPress"
                                             Text="{Binding ButtonData.Command}"
                                             GotFocus="TextBoxGotFocus" />
                                    <Button Grid.Column="1"
                                            Content="Clear"
                                            Tag="ButtonPress"
                                            Width="70"
                                            Margin="6,0,0,0"
                                            Background="#A03030"
                                            Foreground="White"
                                            Click="ClearButton_Click" />
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>

                <!-- Right: commands tree, full height -->
                <Border Grid.Column="1"
                        BorderBrush="{DynamicResource AppBorderSubtle}" BorderThickness="1" CornerRadius="4"
                        Padding="4">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Grid.Row="0"
                                   Text="System Commands"
                                   FontWeight="Bold"
                                   Margin="4,2,0,6" />
                        <ScrollViewer Grid.Row="1"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <TreeView Name="SystemCommandsTreeView"
                                      ItemsSource="{Binding SystemCommandMenus}"
                                      SelectedItem="{Binding CurrentMenuEntry}">
                                <TreeView.DataTemplates>
                                    <TreeDataTemplate DataType="{x:Type local:Models.MenuEntry}"
                                                      ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" PointerPressed="OnPointerPressed">
                                            <TextBlock Text="{Binding Name}" />
                                            <TextBlock Text="(loading…)" Margin="6,0,0,0"
                                                       Foreground="Gray" FontStyle="Italic"
                                                       IsVisible="{Binding IsLoading}" />
                                        </StackPanel>
                                    </TreeDataTemplate>
                                </TreeView.DataTemplates>
                            </TreeView>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
