<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LoupixDeck.ViewModels"
        xmlns:bs="clr-namespace:LoupixDeck.ViewModels.Base"
        xmlns:cnv="clr-namespace:LoupixDeck.Models.Converter"
        xmlns:m="clr-namespace:LoupixDeck.Models"
        x:Class="LoupixDeck.Views.Settings"
        x:DataType="vm:SettingsViewModel"
        x:Name="SettingsWindow"
        mc:Ignorable="d"
        Title="Settings"
        Width="800"
        Height="680">

    <Window.Resources>
        <cnv:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <cnv:ScalingOptionConverter x:Key="ScalingOptionConverter" />
    </Window.Resources>

    <Grid ColumnDefinitions="200,*">

        <!-- Linke Menü-Spalte -->
        <StackPanel Grid.Column="0" Margin="5,10,5,0" Spacing="5">
            <Button Content="General"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="{x:Static bs:SettingsView.General}"
                    HorizontalAlignment="Stretch" />
            <Button Content="OBS Studio"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="{x:Static bs:SettingsView.Obs}"
                    HorizontalAlignment="Stretch" />
            <Button Content="Wallpaper"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="{x:Static bs:SettingsView.Wallpaper}"
                    HorizontalAlignment="Stretch" />
            <Button Content="Haptic"
                    Command="{Binding NavigateCommand}"
                    CommandParameter="{x:Static bs:SettingsView.Haptic}"
                    HorizontalAlignment="Stretch" />
        </StackPanel>

        <Grid Grid.Column="1" Margin="20 5 0 0">
            <StackPanel
                IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=General}">
                <TextBlock Text="General Settings" FontSize="24" FontWeight="Bold" />

                <TextBlock Text="Display Brightness:" Margin="0,10,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Slider Minimum="0" Maximum="100" HorizontalAlignment="Left" TickFrequency="1"
                            IsSnapToTickEnabled="True"
                            Value="{Binding Config.Brightness, Mode=TwoWay}" Width="200" />
                    <TextBlock Text="{Binding Config.Brightness}" VerticalAlignment="Center"></TextBlock>
                </StackPanel>
            </StackPanel>

            <StackPanel
                IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Obs}">
                <TextBlock Text="OBS Settings" FontSize="24" FontWeight="Bold" />

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="IP:" Width="80" VerticalAlignment="Center" />
                    <TextBox Width="200" Text="{Binding ObsConfig.Ip, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Port:" Width="80" VerticalAlignment="Center" />
                    <TextBox Width="200" Text="{Binding ObsConfig.Port, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Password:" Width="80" VerticalAlignment="Center" />
                    <TextBox Width="200" Text="{Binding ObsConfig.Password, Mode=TwoWay}" PasswordChar="*" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0 20 0 0">
                    <Button Content="Save" Width="120" HorizontalContentAlignment="Center"
                            Command="{Binding SaveObsCommand}" />
                    <Button Content="Test Connection" Width="150" HorizontalContentAlignment="Center"
                            Command="{Binding TestConnectionCommand}" />
                    <TextBlock IsVisible="{Binding ConnectionTestVisible}" Text="{Binding ConnectionResult}"
                               Foreground="{Binding TextColor}" />
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="Wallpaper"
                        IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Wallpaper}">
                <TextBlock Text="Wallpaper" FontSize="24" FontWeight="Bold" />

                <!-- Page Selection -->
                <TextBlock Text="Select Page:" Margin="0,10,0,0" />
                <ComboBox Width="200" HorizontalAlignment="Left" Margin="0,5,0,0"
                          ItemsSource="{Binding Pages}"
                          SelectedItem="{Binding SelectedPage, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding PageName}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,10,0,0">
                    <Border BorderBrush="Black" BorderThickness="2" CornerRadius="5">
                        <Image Width="400" Height="190" Source="{Binding SelectedPageWallpaper, Converter={StaticResource SkiaToBitmapConverter}}" />
                    </Border>
                    <StackPanel Spacing="5">
                        <Button Content="Select Image" VerticalAlignment="Top" Command="{Binding SelectImageButtonCommand}" Width="120"></Button>
                        <Button Content="Remove" VerticalAlignment="Top" Command="{Binding RemoveWallpaperCommand}" Width="120"></Button>
                    </StackPanel>
                </StackPanel>
                <TextBlock Text="Opacity:" Margin="0,10,0,0" />
                <Slider Minimum="0" Maximum="1" HorizontalAlignment="Left" TickFrequency="0.1"
                        IsSnapToTickEnabled="True"
                        Value="{Binding SelectedPageWallpaperOpacity, Mode=TwoWay}" Width="200" />

                <!-- Scaling Controls -->
                <ComboBox Width="200" Margin="0,10,0,0"
                          ItemsSource="{Binding WallpaperScalingOptions}"
                          SelectedItem="{Binding SelectedWallpaperScalingOption, Mode=TwoWay}"
                          PlaceholderText="Scaling" />

                <TextBlock Text="Scale:" Margin="0,10,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Slider Minimum="1" Maximum="400" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding WallpaperScaling, Mode=TwoWay}" Width="200" />
                    <TextBlock Text="{Binding WallpaperScaling}"/>
                </StackPanel>

                <!-- Position Controls -->
                <TextBlock Text="Position X:" Margin="0,10,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Slider Minimum="-480" Maximum="480" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding WallpaperPositionX, Mode=TwoWay}" Width="200" />
                    <TextBlock Text="{Binding WallpaperPositionX}" />
                </StackPanel>

                <TextBlock Text="Position Y:" Margin="0,10,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <Slider Minimum="-270" Maximum="270" TickFrequency="1" IsSnapToTickEnabled="True"
                            Value="{Binding WallpaperPositionY, Mode=TwoWay}" Width="200" />
                    <TextBlock Text="{Binding WallpaperPositionY}" />
                </StackPanel>
            </StackPanel>

            <StackPanel
                IsVisible="{Binding CurrentView, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Haptic}">
                <TextBlock Text="Haptic Feedback" FontSize="24" FontWeight="Bold" />

                <CheckBox Content="Enable haptic feedback"
                          IsChecked="{Binding Config.HapticEnabled, Mode=TwoWay}"
                          Margin="0,15,0,0" />

                <!-- First effect (always present, plays immediately on touch) -->
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                        Padding="10" Margin="0,20,20,0"
                        DataContext="{Binding FirstHapticStep}">
                    <StackPanel>
                        <TextBlock Text="First effect (immediate)" FontWeight="Bold" />
                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Effect:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                                      ItemsSource="{Binding #SettingsWindow.((vm:SettingsViewModel)DataContext).VibrationPatterns}"
                                      SelectedValue="{Binding Effect, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="cnv:VibrationPatternItem">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Duration:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <Slider Minimum="2" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding Duration, Mode=TwoWay}" Width="280" />
                                <TextBlock Text="{Binding Duration}" VerticalAlignment="Center" Width="40" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Add-second-effect button (only when there's just one step) -->
                <Button Content="Add second effect" Command="{Binding AddHapticStepCommand}"
                        HorizontalAlignment="Left" Margin="0,8,0,0"
                        IsVisible="{Binding CanAddHapticStep}" />

                <!-- Second effect (optional — fires after delay, while finger still held) -->
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="4"
                        Padding="10" Margin="0,8,20,0"
                        IsVisible="{Binding #SettingsWindow.((vm:SettingsViewModel)DataContext).HasSecondHapticStep}"
                        DataContext="{Binding SecondHapticStep}">
                    <StackPanel>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="Second effect (after delay)" FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Remove"
                                    Command="{Binding #SettingsWindow.((vm:SettingsViewModel)DataContext).RemoveHapticStepCommand}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto" Margin="0,8,0,0">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Effect:" VerticalAlignment="Center" />
                            <ComboBox Grid.Row="0" Grid.Column="1" Width="240" HorizontalAlignment="Left"
                                      ItemsSource="{Binding #SettingsWindow.((vm:SettingsViewModel)DataContext).VibrationPatterns}"
                                      SelectedValue="{Binding Effect, Mode=TwoWay}"
                                      SelectedValueBinding="{Binding Value}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="cnv:VibrationPatternItem">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Delay:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <Slider Minimum="4" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding Delay, Mode=TwoWay}" Width="280" />
                                <TextBlock Text="{Binding Delay}" VerticalAlignment="Center" Width="40" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Duration:" VerticalAlignment="Center" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="10" Margin="0,8,0,0">
                                <Slider Minimum="2" Maximum="255" TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="{Binding Duration, Mode=TwoWay}" Width="280" />
                                <TextBlock Text="{Binding Duration}" VerticalAlignment="Center" Width="40" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>