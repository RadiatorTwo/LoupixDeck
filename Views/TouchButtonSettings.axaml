<Window
    x:Class="LoupixDeck.Views.TouchButtonSettings"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ccp="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.ColorPicker"
    xmlns:local="clr-namespace:LoupixDeck"
    xmlns:vm="using:LoupixDeck.ViewModels"
    xmlns:layers="clr-namespace:LoupixDeck.Models.Layers"
    x:DataType="vm:TouchButtonSettingsViewModel"
    Title="{Binding ButtonLabel}"
    Width="1280"
    SizeToContent="Height"
    MaxHeight="1000"
    mc:Ignorable="d"
    CanResize="False">

    <Window.Styles>
        <StyleInclude Source="avares://LoupixDeck/Views/Styles/SettingsStyles.axaml" />

        <!-- Selection resize handle — size must match TouchButtonSettingsViewModel.HandleSize. -->
        <Style Selector="Rectangle.handle">
            <Setter Property="Width" Value="8" />
            <Setter Property="Height" Value="8" />
            <Setter Property="Fill" Value="White" />
            <Setter Property="Stroke" Value="#FF5B9BD5" />
            <Setter Property="StrokeThickness" Value="1" />
        </Style>
    </Window.Styles>

    <!-- Top area has a fixed height so it never shrinks; the window grows
         downwards (SizeToContent) as the sequence strip wraps onto more rows. -->
    <Grid RowDefinitions="780,Auto" Margin="12">

        <!-- ===== Main area: left panel / preview / properties ===== -->
        <Grid Grid.Row="0" ColumnDefinitions="240,*,360">

            <!-- Left: button settings + layer list -->
            <Border Grid.Column="0" Classes="editor-panel" Margin="0,0,12,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">

                    <StackPanel Grid.Row="0">
                        <TextBlock Classes="panel-title" Text="Button" />
                        <CheckBox Content="Run while device is off"
                                  IsChecked="{Binding ButtonData.EnableWhenOff}"
                                  Margin="0,0,0,4" />
                        <CheckBox Content="Vibration enabled"
                                  IsChecked="{Binding ButtonData.VibrationEnabled}"
                                  Margin="0,0,0,4" />
                        <StackPanel IsEnabled="{Binding ButtonData.VibrationEnabled}">
                            <TextBlock Classes="label" Text="Pattern" Margin="0,2,0,2" />
                            <ComboBox ItemsSource="{Binding VibrationPatterns}"
                                      SelectedItem="{Binding SelectedVibrationPattern}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </StackPanel>

                    <Separator Grid.Row="1" Margin="0,12,0,12" />

                    <StackPanel Grid.Row="2">
                        <TextBlock Classes="panel-title" Text="Layers" />
                        <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,0,0,8">
                            <Button Classes="toolbar" Content="+ Text"
                                    Command="{Binding AddTextLayerCommand}" />
                            <Button Classes="toolbar" Content="+ Image"
                                    Command="{Binding AddImageLayerCommand}" />
                            <Button Classes="toolbar" Content="+ Symbol"
                                    Command="{Binding AddSymbolLayerCommand}" />
                        </StackPanel>
                    </StackPanel>

                    <ListBox Grid.Row="3"
                             ItemsSource="{Binding ButtonData.Layers}"
                             SelectedItem="{Binding SelectedLayer, Mode=TwoWay}"
                             Background="{DynamicResource AppSurfaceLow}"
                             CornerRadius="6">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="8,5" />
                                <Setter Property="MinHeight" Value="32" />
                            </Style>
                        </ListBox.Styles>
                        <ListBox.DataTemplates>
                            <DataTemplate DataType="layers:TextLayer">
                                <Grid ColumnDefinitions="Auto,Auto,*">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              MinWidth="0" Margin="0,0,6,0"
                                              VerticalAlignment="Center"
                                              ToolTip.Tip="Layer visibility" />
                                    <Border Grid.Column="1" Classes="layer-badge">
                                        <TextBlock Text="T" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                            <DataTemplate DataType="layers:ImageLayer">
                                <Grid ColumnDefinitions="Auto,Auto,*">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              MinWidth="0" Margin="0,0,6,0"
                                              VerticalAlignment="Center"
                                              ToolTip.Tip="Layer visibility" />
                                    <Border Grid.Column="1" Classes="layer-badge">
                                        <TextBlock Text="I" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                            <DataTemplate DataType="layers:SymbolLayer">
                                <Grid ColumnDefinitions="Auto,Auto,*">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Visible, Mode=TwoWay}"
                                              MinWidth="0" Margin="0,0,6,0"
                                              VerticalAlignment="Center"
                                              ToolTip.Tip="Layer visibility" />
                                    <Border Grid.Column="1" Classes="layer-badge">
                                        <TextBlock Text="S" />
                                    </Border>
                                    <TextBlock Grid.Column="2" Text="{Binding Name}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                               ToolTip.Tip="{Binding Name}" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.DataTemplates>
                    </ListBox>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Classes="row-action" Content="▲"
                                Command="{Binding MoveLayerUpCommand}"
                                ToolTip.Tip="Move layer up" />
                        <Button Classes="row-action" Content="▼"
                                Command="{Binding MoveLayerDownCommand}"
                                ToolTip.Tip="Move layer down" />
                        <Button Classes="row-action danger"
                                Command="{Binding RemoveLayerCommand}"
                                ToolTip.Tip="Remove layer">
                            <TextBlock Text="&#xF01B4;" FontFamily="{StaticResource MdiFont}" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center: Preview panel with editor canvas + selection overlay -->
            <Border Grid.Column="1" Classes="editor-panel" Padding="8">
                <Grid RowDefinitions="Auto,*">

                    <!-- Preview header + (placeholder) view toolbar -->
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="4,0,4,8">
                        <TextBlock Grid.Column="0" Classes="panel-title" Text="Preview"
                                   Margin="0" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <!-- Zoom tools are not implemented yet — kept visible as
                                 disabled placeholders so the layout is final. The tooltip
                                 sits on a wrapper because a disabled control receives no
                                 pointer events and would never show one itself. -->
                            <Border ToolTip.Tip="Not available yet">
                                <Button Classes="toolbar" Content="Fit" IsEnabled="False" />
                            </Border>
                            <Border ToolTip.Tip="Not available yet">
                                <Button Classes="toolbar" Content="100%" IsEnabled="False" />
                            </Border>
                            <ToggleButton Classes="toolbar" Content="Grid"
                                          IsChecked="{Binding ShowGrid, Mode=TwoWay}"
                                          ToolTip.Tip="Toggle alignment grid" />
                            <ToggleButton Classes="toolbar" Content="Snap"
                                          IsChecked="{Binding SnapToGrid, Mode=TwoWay}"
                                          ToolTip.Tip="Snap layers to the grid while dragging" />
                        </StackPanel>
                    </Grid>

                    <!-- Canvas area: lighter than the app chrome so black buttons stay
                         visible; the Skia preview is transparent outside the frame. -->
                    <Border Grid.Row="1"
                            Background="{DynamicResource AppEditorCanvasBackground}"
                            CornerRadius="6"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Button plate: border + shadow behind the rendered frame.
                                 Sized to the aspect-correct frame so non-square canvases
                                 (e.g. 60×270 side strips) get a matching plate. -->
                            <Border Width="{Binding FrameWidth}" Height="{Binding FrameHeight}"
                                    HorizontalAlignment="Center" VerticalAlignment="Center"
                                    BorderBrush="#55000000" BorderThickness="1"
                                    BoxShadow="0 3 16 0 #50000000"
                                    IsHitTestVisible="False" />

                            <Grid Name="EditorRoot"
                                  Width="600" Height="600"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Background="Transparent"
                                  PointerPressed="Editor_PointerPressed"
                                  PointerMoved="Editor_PointerMoved"
                                  PointerReleased="Editor_PointerReleased">
                                <Image Width="600" Height="600"
                                       Stretch="None"
                                       IsHitTestVisible="False"
                                       Source="{Binding EditorPreview, Converter={StaticResource SkiaToBitmapConverter}}" />
                                <Canvas Width="600" Height="600" Background="Transparent">
                                    <Rectangle Stroke="#CC5B9BD5"
                                               StrokeThickness="1"
                                               StrokeDashArray="4,3"
                                               Fill="Transparent"
                                               IsHitTestVisible="False"
                                               IsVisible="{Binding SelectionVisible}"
                                               Width="{Binding SelectionWidth}"
                                               Height="{Binding SelectionHeight}"
                                               Canvas.Left="{Binding SelectionLeft}"
                                               Canvas.Top="{Binding SelectionTop}" />
                                    <Rectangle Tag="NW" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleNwLeft}" Canvas.Top="{Binding HandleNwTop}" />
                                    <Rectangle Tag="N" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleNLeft}" Canvas.Top="{Binding HandleNTop}" />
                                    <Rectangle Tag="NE" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleNeLeft}" Canvas.Top="{Binding HandleNeTop}" />
                                    <Rectangle Tag="W" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleWLeft}" Canvas.Top="{Binding HandleWTop}" />
                                    <Rectangle Tag="E" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleELeft}" Canvas.Top="{Binding HandleETop}" />
                                    <Rectangle Tag="SW" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleSwLeft}" Canvas.Top="{Binding HandleSwTop}" />
                                    <Rectangle Tag="S" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleSLeft}" Canvas.Top="{Binding HandleSTop}" />
                                    <Rectangle Tag="SE" Classes="handle"
                                               IsVisible="{Binding ScaleHandlesVisible}"
                                               Canvas.Left="{Binding HandleSeLeft}" Canvas.Top="{Binding HandleSeTop}" />
                                </Canvas>
                            </Grid>

                            <!-- Resolution badge -->
                            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Margin="0,0,10,10"
                                    Background="#66000000" CornerRadius="4"
                                    Padding="8,3"
                                    IsHitTestVisible="False">
                                <TextBlock Text="{Binding CanvasSizeText}"
                                           Foreground="#E0FFFFFF" FontSize="11" />
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Tabs (Properties / Commands) -->
            <TabControl Grid.Column="2" Name="RightTabs" Margin="12,0,0,0">
                <TabItem Header="Properties">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,4,0" Spacing="12">

                            <!-- Button-wide settings -->
                            <Border Classes="editor-panel">
                                <StackPanel>
                                    <TextBlock Classes="panel-title"
                                               Text="{Binding ButtonNumber, StringFormat='Button {0}'}" />
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Classes="label" Text="Background"
                                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <ccp:ColorPicker Grid.Column="1"
                                                         Color="{Binding ButtonData.BackColor}"
                                                         Width="110" HorizontalAlignment="Left" />
                                        <Button Grid.Column="2" Content="Reset…"
                                                Click="ResetButton_Click"
                                                Background="#A03030" Foreground="White"
                                                ToolTip.Tip="Clears layers, colors and the command of this button" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Per-layer panel -->
                            <Border Classes="editor-panel">
                                <StackPanel>
                                    <TextBlock Classes="hint"
                                               Text="Select a layer to edit its properties."
                                               IsVisible="{Binding SelectedLayer, Converter={x:Static ObjectConverters.IsNull}}" />
                                    <ContentControl Content="{Binding SelectedLayer}">
                                <ContentControl.DataTemplates>

                                    <!-- Image layer -->
                                    <DataTemplate DataType="layers:ImageLayer">
                                        <StackPanel>
                                            <TextBlock Classes="panel-title" Text="Selected Layer: Image" />

                                            <TextBlock Classes="label" Text="Name" />
                                            <TextBox Text="{Binding Name, Mode=TwoWay}" Margin="0,2,0,8" />

                                            <TextBlock Classes="label" Text="Asset" />
                                            <TextBlock Text="{Binding AssetRelativePath}"
                                                       Foreground="{DynamicResource AppTextSecondary}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,8" />

                                            <TextBlock Classes="label" Text="Position" />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,8">
                                                <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding PositionX, Mode=TwoWay}"
                                                               Minimum="-200" Maximum="200"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="Y" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding PositionY, Mode=TwoWay}"
                                                               Minimum="-200" Maximum="200"
                                                               Increment="1" FormatString="0" />
                                            </Grid>

                                            <TextBlock Classes="label" Text="Size (px)" />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,8">
                                                <TextBlock Grid.Column="0" Text="W" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding DisplayWidth, Mode=TwoWay}"
                                                               Minimum="1" Maximum="4000"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="H" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding DisplayHeight, Mode=TwoWay}"
                                                               Minimum="1" Maximum="4000"
                                                               Increment="1" FormatString="0" />
                                            </Grid>

                                            <TextBlock Classes="label" Text="Crop (source rect)" Margin="0,4,0,0"
                                                       ToolTip.Tip="Hold Alt + drag a handle to crop. Hold Shift to unlock aspect ratio while scaling." />
                                            <Grid ColumnDefinitions="16,*,12,16,*"
                                                  RowDefinitions="Auto,Auto" Margin="0,2,0,4">
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="L" VerticalAlignment="Center" Margin="0,0,6,4" />
                                                <NumericUpDown Grid.Row="0" Grid.Column="1" Margin="0,0,0,4"
                                                               Value="{Binding SourceRect.Left, Mode=TwoWay}"
                                                               Minimum="0" />
                                                <TextBlock Grid.Row="0" Grid.Column="3" Text="T" VerticalAlignment="Center" Margin="0,0,6,4" />
                                                <NumericUpDown Grid.Row="0" Grid.Column="4" Margin="0,0,0,4"
                                                               Value="{Binding SourceRect.Top, Mode=TwoWay}"
                                                               Minimum="0" />
                                                <TextBlock Grid.Row="1" Grid.Column="0" Text="R" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Row="1" Grid.Column="1"
                                                               Value="{Binding SourceRect.Right, Mode=TwoWay}"
                                                               Minimum="0" />
                                                <TextBlock Grid.Row="1" Grid.Column="3" Text="B" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Row="1" Grid.Column="4"
                                                               Value="{Binding SourceRect.Bottom, Mode=TwoWay}"
                                                               Minimum="0" />
                                            </Grid>
                                            <TextBlock Classes="hint"
                                                       Text="All zeros = use full image." />
                                        </StackPanel>
                                    </DataTemplate>

                                    <!-- Text layer -->
                                    <DataTemplate DataType="layers:TextLayer">
                                        <StackPanel>
                                            <TextBlock Classes="panel-title" Text="Selected Layer: Text" />

                                            <TextBlock Classes="label" Text="Name" />
                                            <TextBox Text="{Binding Name, Mode=TwoWay}" Margin="0,2,0,8" />

                                            <TextBlock Classes="label" Text="Text" />
                                            <TextBox Text="{Binding Text, Mode=TwoWay}" Margin="0,2,0,8" />

                                            <Grid ColumnDefinitions="*,12,*" Margin="0,0,0,8">
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Classes="label" Text="Size" />
                                                    <NumericUpDown Value="{Binding TextSize, Mode=TwoWay}"
                                                                   Minimum="4" Maximum="80"
                                                                   Increment="1" FormatString="0"
                                                                   Margin="0,2,0,0" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Classes="label" Text="Color" />
                                                    <ccp:ColorPicker Color="{Binding TextColor, Mode=TwoWay}"
                                                                     HorizontalAlignment="Stretch"
                                                                     Margin="0,2,0,0" />
                                                </StackPanel>
                                            </Grid>

                                            <TextBlock Classes="label" Text="Style" />
                                            <WrapPanel Margin="0,2,0,4">
                                                <CheckBox Content="Bold" IsChecked="{Binding Bold, Mode=TwoWay}"
                                                          Margin="0,0,12,0" />
                                                <CheckBox Content="Italic" IsChecked="{Binding Italic, Mode=TwoWay}"
                                                          Margin="0,0,12,0" />
                                                <CheckBox Content="Center in box" IsChecked="{Binding Centered, Mode=TwoWay}"
                                                          ToolTip.Tip="Centers the text inside its box and positions relative to the button center" />
                                            </WrapPanel>

                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                <CheckBox Content="Outline" IsChecked="{Binding Outlined, Mode=TwoWay}"
                                                          Margin="0,0,10,0" />
                                                <ccp:ColorPicker Color="{Binding OutlineColor, Mode=TwoWay}"
                                                                 Width="80"
                                                                 IsVisible="{Binding Outlined}" />
                                            </StackPanel>

                                            <TextBlock Classes="label" Text="Position" />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,8">
                                                <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding PositionX, Mode=TwoWay}"
                                                               Minimum="-100" Maximum="100"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="Y" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding PositionY, Mode=TwoWay}"
                                                               Minimum="-100" Maximum="100"
                                                               Increment="1" FormatString="0" />
                                            </Grid>

                                            <TextBlock Classes="label" Text="Box size"
                                                       ToolTip.Tip="Layout area for the text — drag handles in the preview to change." />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,0">
                                                <TextBlock Grid.Column="0" Text="W" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding BoxWidth, Mode=TwoWay}"
                                                               Minimum="10" Maximum="400"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="H" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding BoxHeight, Mode=TwoWay}"
                                                               Minimum="10" Maximum="400"
                                                               Increment="1" FormatString="0" />
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>

                                    <!-- Symbol layer -->
                                    <DataTemplate DataType="layers:SymbolLayer">
                                        <StackPanel>
                                            <TextBlock Classes="panel-title" Text="Selected Layer: Symbol" />

                                            <TextBlock Classes="label" Text="Name" />
                                            <TextBox Text="{Binding Name, Mode=TwoWay}" Margin="0,2,0,8" />

                                            <TextBlock Classes="label" Text="Symbol" />
                                            <Grid ColumnDefinitions="Auto,*" Margin="0,0,0,6">
                                                <Border Grid.Column="0"
                                                        Width="48" Height="48"
                                                        BorderThickness="1" BorderBrush="{DynamicResource AppBorderSubtle}"
                                                        Background="{DynamicResource AppSurfaceLow}"
                                                        Margin="0,0,8,0">
                                                    <TextBlock Text="{Binding Glyph}"
                                                               FontFamily="{StaticResource MdiFont}"
                                                               FontSize="28"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <Button Grid.Column="1"
                                                        Content="Change Symbol…"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Stretch"
                                                        Click="ChangeSymbol_Click" />
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                <TextBlock Classes="label" Text="Tint" Width="60" VerticalAlignment="Center" />
                                                <ccp:ColorPicker Color="{Binding Tint, Mode=TwoWay}" Width="80" />
                                            </StackPanel>

                                            <Separator Margin="0,6,0,6" />
                                            <TextBlock Classes="label" Text="Style" Margin="0,0,0,4" />

                                            <!-- Gradient fill -->
                                            <CheckBox Content="Gradient fill"
                                                      IsChecked="{Binding UseGradient, Mode=TwoWay}" />
                                            <StackPanel IsVisible="{Binding UseGradient}" Margin="16,2,0,4">
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="From:" Width="50" VerticalAlignment="Center" />
                                                    <ccp:ColorPicker Color="{Binding GradientStartColor, Mode=TwoWay}" Width="80" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="To:" Width="50" VerticalAlignment="Center" />
                                                    <ccp:ColorPicker Color="{Binding GradientEndColor, Mode=TwoWay}" Width="80" />
                                                </StackPanel>
                                                <TextBlock Text="Angle" />
                                                <Grid ColumnDefinitions="*,50">
                                                    <Slider Grid.Column="0"
                                                            Minimum="0" Maximum="360"
                                                            Value="{Binding GradientAngle, Mode=TwoWay}"
                                                            IsSnapToTickEnabled="True" TickFrequency="1" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding GradientAngle, StringFormat={}{0:0}°}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- Outline -->
                                            <CheckBox Content="Outline"
                                                      IsChecked="{Binding Outlined, Mode=TwoWay}"
                                                      Margin="0,2,0,0" />
                                            <StackPanel IsVisible="{Binding Outlined}" Margin="16,2,0,4">
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="Color:" Width="50" VerticalAlignment="Center" />
                                                    <ccp:ColorPicker Color="{Binding OutlineColor, Mode=TwoWay}" Width="80" />
                                                </StackPanel>
                                                <TextBlock Text="Width" />
                                                <Grid ColumnDefinitions="*,50">
                                                    <Slider Grid.Column="0"
                                                            Minimum="0.5" Maximum="20"
                                                            Value="{Binding OutlineWidth, Mode=TwoWay}"
                                                            TickFrequency="0.5" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding OutlineWidth, StringFormat={}{0:0.0}}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                            </StackPanel>

                                            <!-- Drop shadow -->
                                            <CheckBox Content="Shadow"
                                                      IsChecked="{Binding Shadow, Mode=TwoWay}"
                                                      Margin="0,2,0,0" />
                                            <StackPanel IsVisible="{Binding Shadow}" Margin="16,2,0,4">
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                                    <TextBlock Text="Color:" Width="50" VerticalAlignment="Center" />
                                                    <ccp:ColorPicker Color="{Binding ShadowColor, Mode=TwoWay}" Width="80" />
                                                </StackPanel>
                                                <TextBlock Text="Blur" />
                                                <Grid ColumnDefinitions="*,50">
                                                    <Slider Grid.Column="0"
                                                            Minimum="0" Maximum="20"
                                                            Value="{Binding ShadowBlur, Mode=TwoWay}"
                                                            TickFrequency="0.5" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ShadowBlur, StringFormat={}{0:0.0}}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                                <TextBlock Text="Offset X" />
                                                <Grid ColumnDefinitions="*,50">
                                                    <Slider Grid.Column="0"
                                                            Minimum="-20" Maximum="20"
                                                            Value="{Binding ShadowOffsetX, Mode=TwoWay}"
                                                            IsSnapToTickEnabled="True" TickFrequency="1" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ShadowOffsetX}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                                <TextBlock Text="Offset Y" />
                                                <Grid ColumnDefinitions="*,50">
                                                    <Slider Grid.Column="0"
                                                            Minimum="-20" Maximum="20"
                                                            Value="{Binding ShadowOffsetY, Mode=TwoWay}"
                                                            IsSnapToTickEnabled="True" TickFrequency="1" />
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ShadowOffsetY}"
                                                               VerticalAlignment="Center"
                                                               HorizontalAlignment="Right" />
                                                </Grid>
                                            </StackPanel>

                                            <Separator Margin="0,6,0,8" />

                                            <TextBlock Classes="label" Text="Position" />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,8">
                                                <TextBlock Grid.Column="0" Text="X" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding PositionX, Mode=TwoWay}"
                                                               Minimum="-200" Maximum="200"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="Y" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding PositionY, Mode=TwoWay}"
                                                               Minimum="-200" Maximum="200"
                                                               Increment="1" FormatString="0" />
                                            </Grid>

                                            <TextBlock Classes="label" Text="Size (px)" />
                                            <Grid ColumnDefinitions="16,*,12,16,*" Margin="0,2,0,0">
                                                <TextBlock Grid.Column="0" Text="W" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="1"
                                                               Value="{Binding DisplayWidth, Mode=TwoWay}"
                                                               Minimum="1" Maximum="4000"
                                                               Increment="1" FormatString="0" />
                                                <TextBlock Grid.Column="3" Text="H" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <NumericUpDown Grid.Column="4"
                                                               Value="{Binding DisplayHeight, Mode=TwoWay}"
                                                               Minimum="1" Maximum="4000"
                                                               Increment="1" FormatString="0" />
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.DataTemplates>
                                    </ContentControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="Commands">
                    <!-- Command library only — the assigned sequence lives in the
                         pipeline strip at the bottom of the window, so the tree
                         keeps its full height and never shifts. Double-click an
                         entry to append it, or drag it into the strip. -->
                    <ScrollViewer Margin="0,4,0,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TreeView Name="SystemCommandsTreeView" ItemsSource="{Binding SystemCommandMenus}"
                                  SelectedItem="{Binding CurrentMenuEntry}"
                                  PointerMoved="SystemCommandsTree_PointerMoved"
                                  PointerReleased="SystemCommandsTree_PointerReleased"
                                  PointerCaptureLost="SystemCommandsTree_PointerCaptureLost">
                            <TreeView.DataTemplates>
                                <TreeDataTemplate DataType="{x:Type local:Models.MenuEntry}"
                                                  ItemsSource="{Binding Children}">
                                    <!-- Transparent, full-width root so a click anywhere
                                         on the row is caught, not only on the glyph text. -->
                                    <Grid Background="Transparent"
                                          HorizontalAlignment="Stretch"
                                          PointerPressed="OnPointerPressed"
                                          DoubleTapped="OnCommandDoubleTapped">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" />
                                            <TextBlock Text="(loading…)" Margin="6,0,0,0"
                                                       Foreground="Gray" FontStyle="Italic"
                                                       IsVisible="{Binding IsLoading}" />
                                        </StackPanel>
                                    </Grid>
                                </TreeDataTemplate>
                            </TreeView.DataTemplates>
                        </TreeView>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ===== Bottom: command sequence pipeline strip =====
             The assigned commands as a left-to-right execution chain. Fixed
             height, scrolls horizontally — adding commands never reflows the
             rest of the window. Doubles as the drop target for tree drags. -->
        <Border Grid.Row="1" Name="CommandDropZone"
                Classes="sequence-strip" Margin="0,12,0,0">
            <Grid ColumnDefinitions="Auto,*,Auto">

                <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,16,0">
                    <TextBlock Text="Sequence" FontWeight="SemiBold" />
                    <TextBlock Classes="hint"
                               Text="{Binding Commands.Count, StringFormat='{}{0} command(s)'}" />
                </StackPanel>

                <Panel Grid.Column="1" MinHeight="40">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="320">
                        <ItemsControl Name="CommandList"
                                      ItemsSource="{Binding Commands}"
                                      VerticalAlignment="Top"
                                      PointerMoved="CommandList_PointerMoved"
                                      PointerReleased="CommandList_PointerReleased"
                                      PointerCaptureLost="CommandList_PointerCaptureLost">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- Chips wrap onto multiple rows; the chain
                                         still reads left → right, top → bottom in
                                         execution order. -->
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CommandSegment}">
                                    <!-- Connector gutter + chip. The arrow lives in a
                                         fixed-width gutter so showing/hiding it never
                                         re-packs the row; it is hidden on the first chip
                                         of each wrapped row (ShowConnector, maintained
                                         from layout in code-behind), which keeps every
                                         row left-aligned. -->
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Panel Width="22">
                                            <TextBlock Classes="sequence-arrow" Text="&#x2192;"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       IsVisible="{Binding ShowConnector}" />
                                        </Panel>
                                        <Border Classes="command-chip"
                                                Classes.dragging="{Binding IsDragging}"
                                                ToolTip.Tip="{Binding DisplayName}">
                                            <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto">
                                                <Border Grid.Column="0" Classes="drag-handle chip-grip"
                                                        VerticalAlignment="Center"
                                                        ToolTip.Tip="Drag to reorder"
                                                        PointerPressed="CommandDragHandle_PointerPressed">
                                                    <TextBlock Text="&#xF01DB;" />
                                                </Border>

                                                <Border Grid.Column="1" Classes="chip-index"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Position}" />
                                                </Border>

                                                <TextBlock Grid.Column="2" Classes="chip-title"
                                                           Text="{Binding DisplayName}"
                                                           VerticalAlignment="Center" />

                                                <Button Grid.Column="3" Classes="chip-action"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource MdiFont}"
                                                        Content="&#xF0140;"
                                                        ToolTip.Tip="Edit parameters">
                                                    <Button.Flyout>
                                                        <Flyout Placement="Top">
                                                            <Panel Width="300">
                                                                <!-- Known command: structured parameter fields -->
                                                                <StackPanel Spacing="4"
                                                                            IsVisible="{Binding IsKnown}">
                                                                    <ItemsControl ItemsSource="{Binding Parameters}">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate DataType="{x:Type vm:CommandParameter}">
                                                                                <Grid ColumnDefinitions="120,*"
                                                                                      Margin="0,0,0,4">
                                                                                    <TextBlock Grid.Column="0"
                                                                                               Classes="editor-label"
                                                                                               Text="{Binding Name}"
                                                                                               VerticalAlignment="Center"
                                                                                               Margin="0,0,10,0" />
                                                                                    <TextBox Grid.Column="1"
                                                                                             Text="{Binding Value, Mode=TwoWay}"
                                                                                             IsVisible="{Binding IsText}" />
                                                                                    <ComboBox Grid.Column="1"
                                                                                              HorizontalAlignment="Stretch"
                                                                                              ItemsSource="{Binding Options}"
                                                                                              SelectedItem="{Binding Value, Mode=TwoWay}"
                                                                                              IsVisible="{Binding IsEnum}" />
                                                                                    <CheckBox Grid.Column="1"
                                                                                              IsChecked="{Binding BoolValue, Mode=TwoWay}"
                                                                                              IsVisible="{Binding IsBool}" />
                                                                                </Grid>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                    <TextBlock Classes="hint"
                                                                               Text="This command has no parameters."
                                                                               IsVisible="{Binding !Parameters.Count}" />
                                                                </StackPanel>

                                                                <!-- Unknown / shell command: single free-text field -->
                                                                <Grid ColumnDefinitions="120,*"
                                                                      IsVisible="{Binding !IsKnown}">
                                                                    <TextBlock Grid.Column="0"
                                                                               Classes="editor-label"
                                                                               Text="Command"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,10,0" />
                                                                    <TextBox Grid.Column="1"
                                                                             Text="{Binding ShellText, Mode=TwoWay}" />
                                                                </Grid>
                                                            </Panel>
                                                        </Flyout>
                                                    </Button.Flyout>
                                                </Button>

                                                <Button Grid.Column="4" Classes="chip-action danger"
                                                        VerticalAlignment="Center"
                                                        FontFamily="{StaticResource MdiFont}"
                                                        Content="&#xF01B4;"
                                                        ToolTip.Tip="Remove command"
                                                        Click="RemoveCommand_Click" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Classes="hint" VerticalAlignment="Center"
                               Text="No commands yet — double-click an entry in the Commands tab to add one, or drag it down here."
                               IsVisible="{Binding !Commands.Count}" />
                </Panel>

                <Button Grid.Column="2" Content="Clear"
                        Command="{Binding ClearCommandCommand}"
                        IsEnabled="{Binding HasCommand}"
                        VerticalAlignment="Top"
                        Margin="16,0,0,0" MinWidth="80"
                        HorizontalContentAlignment="Center"
                        ToolTip.Tip="Remove all assigned commands (keeps layers and colors)" />
            </Grid>
        </Border>

        <!-- ===== Drag ghost =====
             Floating chip that follows the cursor while dragging a command from
             the tree into the sequence strip. Spans the whole window, never hit-
             tests, and is positioned from code-behind during the drag. -->
        <Canvas Name="DragGhostLayer" Grid.Row="0" Grid.RowSpan="2"
                IsHitTestVisible="False" IsVisible="False">
            <!-- Insertion marker: vertical bar shown at the slot where the
                 dragged command will land. Positioned from code-behind. -->
            <Rectangle Name="DropMarker" Width="3"
                       Fill="#4DA3FF" RadiusX="1.5" RadiusY="1.5"
                       IsVisible="False" />
            <Border Name="DragGhost" Classes="drag-ghost">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="&#xF01DB;" FontFamily="{StaticResource MdiFont}"
                               FontSize="16" VerticalAlignment="Center"
                               Foreground="{DynamicResource AppTextMuted}" />
                    <TextBlock Name="DragGhostText" Classes="chip-title"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>
        </Canvas>
    </Grid>
</Window>
