<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:LoupixDeck.ViewModels"
        mc:Ignorable="d" 
        d:DesignWidth="800" d:DesignHeight="450"
        Width="800" Height="450"
        WindowStartupLocation="CenterScreen"
        x:Class="LoupixDeck.Views.MacroEditor"
        x:DataType="vm:MacroEditorViewModel"
        d:DataContext="{d:DesignInstance Type=vm:MacroEditorViewModel, IsDesignTimeCreatable=True}"
        Icon="avares://LoupixDeck/Assets/logo.ico"
        x:Name="MacroEditor"
        Title="Macro Editor">
    Welcome to Avalonia!
</Window>
