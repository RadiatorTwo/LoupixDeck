<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    LoupixDeck.PluginSdk is developed in its own repository
    (https://github.com/RadiatorTwo/LoupixDeck.PluginSdk) and consumed here as a
    NuGet package. During local development the package is resolved from the
    sibling repo's ./nupkg output folder. Clone both repositories side by side:

        <parent>/LoupixDeck/
        <parent>/LoupixDeck.PluginSdk/

    Build the SDK once (dotnet build -c Release) so the .nupkg exists, then
    build LoupixDeck. Once the SDK is published to nuget.org this local source
    can be removed.
  -->
  <packageSources>
    <add key="LoupixDeck.PluginSdk (local)" value="..\LoupixDeck.PluginSdk\nupkg" />
  </packageSources>
</configuration>
