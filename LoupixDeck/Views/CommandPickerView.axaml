<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:LoupixDeck.ViewModels.CommandPicker"
             mc:Ignorable="d"
             x:Class="LoupixDeck.Views.CommandPickerView"
             x:DataType="vm:CommandPickerViewModel"
             x:CompileBindings="True">

    <UserControl.Styles>
        <StyleInclude Source="avares://LoupixDeck/Views/Styles/SettingsStyles.axaml" />
        <StyleInclude Source="avares://LoupixDeck/Views/Styles/CommandPickerStyles.axaml" />
    </UserControl.Styles>

    <!-- Implicit templates resolved by data type: command rows (detail list + search
         results) and drillable sub-folders (detail list only). -->
    <UserControl.DataTemplates>
        <!-- Command row: selectable + draggable, carries the insertion payload. -->
        <DataTemplate DataType="vm:CommandRowViewModel">
            <Border Classes="picker-row-face"
                    Classes.selected="{Binding IsSelected}"
                    Focusable="True"
                    Background="Transparent"
                    PointerPressed="Row_PointerPressed"
                    DoubleTapped="Row_DoubleTapped"
                    KeyDown="Row_KeyDown">
                <Grid ColumnDefinitions="Auto,Auto,*">
                    <Border Grid.Column="0" Classes="picker-row-bar" />
                    <TextBlock Grid.Column="1" Classes="picker-row-icon" Text="{Binding Icon}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Classes="picker-row-title" Text="{Binding Title}" />
                            <!-- Badge for a rotary command group (fills several slots at once). -->
                            <Border Classes="picker-group-badge" IsVisible="{Binding IsCommandGroup}"
                                    ToolTip.Tip="Fills all rotary actions (turn left / right / press) at once">
                                <TextBlock Text="Group" />
                            </Border>
                        </StackPanel>
                        <TextBlock Classes="picker-row-desc" Text="{Binding Description}"
                                   IsVisible="{Binding HasDescription}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- Group node: an inline accordion header that expands/collapses its children
             (command rows and/or further nested groups → resolved recursively). -->
        <DataTemplate DataType="vm:CommandGroupNodeViewModel">
            <StackPanel>
                <ToggleButton Classes="picker-group"
                              IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                              ToolTip.Tip="Expand / collapse group">
                    <Grid ColumnDefinitions="Auto,Auto,*,Auto">
                        <TextBlock Grid.Column="0" Classes="picker-group-chevron" />
                        <TextBlock Grid.Column="1" Classes="picker-row-icon" Text="{Binding Icon}" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                            <TextBlock Classes="picker-row-title" Text="{Binding Title}" />
                            <TextBlock Classes="picker-row-desc" Text="{Binding Description}"
                                       IsVisible="{Binding HasDescription}" />
                        </StackPanel>
                        <Border Grid.Column="3" Classes="picker-count" VerticalAlignment="Center">
                            <TextBlock Text="{Binding Count}" />
                        </Border>
                    </Grid>
                </ToggleButton>
                <!-- Nested content, indented; implicit templates resolve rows vs. groups. -->
                <ItemsControl ItemsSource="{Binding Children}"
                              IsVisible="{Binding IsExpanded}"
                              Margin="14,0,0,0" />
            </StackPanel>
        </DataTemplate>
    </UserControl.DataTemplates>

    <Grid RowDefinitions="Auto,*,Auto"
          Margin="4"
          KeyDown="Root_KeyDown">

        <!-- 1. Search bar -->
        <Border Grid.Row="0" Margin="8,4,8,10"
                Background="{DynamicResource AppControlBackground}"
                BorderBrush="{DynamicResource AppBorderSubtle}" BorderThickness="1"
                CornerRadius="8" Padding="10,6">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <TextBlock Grid.Column="0" FontFamily="{DynamicResource MdiFont}"
                           Text="&#xF0349;" FontSize="18"
                           Foreground="{DynamicResource AppTextSecondary}"
                           VerticalAlignment="Center" Margin="0,0,8,0" />
                <TextBox Grid.Column="1" Name="SearchBox"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         Watermark="Search commands..."
                         BorderThickness="0" Background="Transparent"
                         VerticalAlignment="Center" />
                <Border Grid.Column="2" Classes="picker-kbd">
                    <TextBlock Text="Ctrl K" />
                </Border>
            </Grid>
        </Border>

        <!-- 2. Main area: card grid (or search results) on top, detail list below.
             Both halves always share the height evenly (1:1). -->
        <Grid Grid.Row="1" RowDefinitions="*,*">

            <!-- Card grid + search results share the scroll region. The scrollbar is
                 hidden (wheel scrolling still works) so its overlay never covers the
                 cards or shifts the right-aligned section toggle. -->
            <ScrollViewer Grid.Row="0" Name="CardScroll"
                          VerticalScrollBarVisibility="Hidden"
                          HorizontalScrollBarVisibility="Disabled" Padding="4,0">
              <!-- Pinned to the viewport width so every section header spans the full
                   width regardless of how many sections are expanded — otherwise the
                   collapsed content shrinks to its text and the right-aligned expand
                   toggle drifts with each section's title length. -->
              <Panel Width="{Binding #CardScroll.Viewport.Width}">

                <!-- Card grid (normal mode) -->
                <ItemsControl ItemsSource="{Binding Sections}"
                              IsVisible="{Binding !IsSearching}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CommandSectionViewModel">
                            <StackPanel Margin="0,0,0,8">
                                <!-- Section header -->
                                <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,10,4,4">
                                    <TextBlock Grid.Column="0" Classes="picker-section-icon" Text="{Binding Icon}" />
                                    <TextBlock Grid.Column="1" Classes="picker-section-title" Text="{Binding Title}" />
                                    <ToggleButton Grid.Column="2" Classes="card-expand"
                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                  ToolTip.Tip="Collapse / expand section" />
                                </Grid>

                                <!-- Two-column category cards -->
                                <ItemsControl ItemsSource="{Binding Categories}"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:CommandCategoryViewModel">
                                            <Button Classes="picker-card" Click="Card_Click">
                                                <Border Classes="picker-card-face"
                                                        Classes.selected="{Binding IsSelected}">
                                                    <StackPanel>
                                                        <Grid ColumnDefinitions="*,Auto">
                                                            <TextBlock Grid.Column="0" Classes="picker-card-icon"
                                                                       Text="{Binding Icon}" />
                                                            <Border Grid.Column="1" Classes="picker-count">
                                                                <TextBlock Text="{Binding Count}" />
                                                            </Border>
                                                        </Grid>
                                                        <TextBlock Classes="picker-card-title" Text="{Binding Title}" />
                                                        <TextBlock Classes="picker-card-desc" Text="{Binding Description}"
                                                                   IsVisible="{Binding HasDescription}" />
                                                    </StackPanel>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Search results (search mode) -->
                <ItemsControl ItemsSource="{Binding SearchResults}"
                              IsVisible="{Binding IsSearching}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CommandSearchGroupViewModel">
                            <StackPanel Margin="0,0,0,6">
                                <Grid ColumnDefinitions="Auto,*" Margin="4,10,4,4">
                                    <TextBlock Grid.Column="0" Classes="picker-section-icon"
                                               FontSize="16" Width="22" Text="{Binding Icon}" />
                                    <TextBlock Grid.Column="1" Classes="picker-detail-title" Text="{Binding Title}" />
                                </Grid>
                                <ItemsControl ItemsSource="{Binding Commands}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Panel>
            </ScrollViewer>

            <!-- 4./6./7. Detail area for the selected category (hidden while searching).
                 Direct commands render as rows; sub-groups render as inline accordions. -->
            <Grid Grid.Row="1" RowDefinitions="Auto,*"
                  IsVisible="{Binding HasSelectedCategory}">
                <Border Grid.Row="0" Classes="picker-detail-header"
                        IsVisible="{Binding !IsSearching}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <TextBlock Grid.Column="0" Classes="picker-detail-icon"
                                   Text="{Binding SelectedCategory.Icon}" />
                        <TextBlock Grid.Column="1" Classes="picker-detail-title"
                                   Text="{Binding SelectedCategory.Title}" />
                        <TextBlock Grid.Column="2" Classes="picker-detail-count"
                                   Text="{Binding SelectedCategory.Count, StringFormat='{}{0} commands'}" />
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Hidden"
                              HorizontalScrollBarVisibility="Disabled"
                              IsVisible="{Binding !IsSearching}"
                              Padding="4,0">
                    <ItemsControl ItemsSource="{Binding SelectedCategory.DetailNodes}" />
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- 3. Footer hint -->
        <Border Grid.Row="2" Classes="picker-footer" Margin="4,6,4,0">
            <TextBlock Classes="picker-footer-text"
                       Text="Tip: Use &#x2191;&#x2193; to navigate, Enter to add, Space to expand groups, Esc to clear search" />
        </Border>
    </Grid>
</UserControl>
