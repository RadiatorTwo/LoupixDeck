<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LoupixDeck.ViewModels"
        xmlns:models="using:LoupixDeck.Models"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        x:Class="LoupixDeck.Views.MainWindow"
        x:DataType="vm:MainShellViewModel"
        d:DataContext="{d:DesignInstance Type=vm:MainShellViewModel, IsDesignTimeCreatable=True}"
        Icon="avares://LoupixDeck/Assets/logo.ico"
        Title="LoupixDeck"
        x:Name="RootWindow">
    <!-- Copy/cut/paste of the selected button or side display (issue #166). Routed to the
         active device's VM. A focused TextBox (page name) consumes these first, so editing
         a page name still gets normal text copy/paste. Clear is intentionally menu-only
         (no keyboard shortcut) so an accidental key press can't wipe a button while there
         is no undo yet. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+C" Command="{Binding SelectedDevice.CopySelectedCommand}" />
        <KeyBinding Gesture="Ctrl+X" Command="{Binding SelectedDevice.CutSelectedCommand}" />
        <KeyBinding Gesture="Ctrl+V" Command="{Binding SelectedDevice.PasteSelectedCommand}" />
    </Window.KeyBindings>
    <Window.Styles>
        <!-- Device touch button chrome. The Razer centre grid relies on this
             window-level style; the Live S layout overrides Button[Tag=Touch]
             locally with a chrome-free variant. -->
        <Style Selector="Button[Tag=Touch]">
            <Setter Property="Background" Value="{DynamicResource DeviceScreenBackground}" />
            <Setter Property="BorderBrush" Value="{DynamicResource DeviceButtonBorder}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="90" />
            <Setter Property="Height" Value="90" />
            <Setter Property="Effect" Value="{StaticResource InnerShadow}" />
        </Style>
        <Style Selector="Button[Tag=Led]">
            <Setter Property="Background" Value="{DynamicResource DeviceScreenBackground}" />
            <Setter Property="Effect" Value="{StaticResource InnerShadow}" />
        </Style>

        <!-- Compact page pager (shared by every device layout): a single name field
             flanked by prev/next chevrons plus add/delete. Constant size regardless
             of how many pages exist, so the window never grows with page count. -->
        <Style Selector="Border.Pager">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceLow}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="6,4" />
        </Style>

        <!-- Prev/next chevrons and add/delete actions share a chrome-free custom
             template so hover/press never paint the default grey button box. -->
        <Style Selector="Button.PagerBtn">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PageChipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.PagerBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundHover}" />
            <Setter Property="BorderBrush" Value="{StaticResource PageActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="2" />
        </Style>
        <!-- Chevrons sit flush either side of the name field (no rounded outer edge). -->
        <Style Selector="Button.PagerNav">
            <Setter Property="FontSize" Value="18" />
        </Style>
        <!-- Delete gets a danger-coloured hover so it reads apart from add. -->
        <Style Selector="Button.PagerBtn.delete:pointerover">
            <Setter Property="Background" Value="#5A2730" />
            <Setter Property="BorderBrush" Value="#B05560" />
            <Setter Property="Foreground" Value="#FF9090" />
        </Style>

        <!-- Editable page-name field at the centre of the pager. Watermark shows the
             page number (PageName fallback) when the page has no custom name. -->
        <Style Selector="TextBox.PageName">
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="28" />
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="6,1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <!-- The placeholder (shown when no custom page name is set) defaults to a very
             faint Fluent colour that is hard to read, especially in Light mode. Avalonia 12
             exposes it as TextBox.PlaceholderForeground (an earlier attempt to restyle a
             PART_Watermark TextBlock did nothing — that element no longer exists), so set it
             to the primary text colour so the fallback page name reads like a typed name. -->
        <Style Selector="TextBox.PageName">
            <Setter Property="PlaceholderForeground" Value="{DynamicResource AppTextPrimary}" />
        </Style>

        <!-- "current / total" page counter shown beside the name field. -->
        <Style Selector="TextBlock.PageCount">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="2,0,4,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
        </Style>

        <!-- ───────── Device / Profile / Workspace switcher header (issue #132) ─────────
             A single top bar that hosts the three cascading selectors (Device → Profile →
             Workspace), styled to sit above the device layout like the original software.
             The three selectors are fused into ONE framed bar (SwitcherGroup) with fine
             inner dividers, so Device / Profile / Workspace read as a single context path
             rather than three separate drop-downs. -->
        <Style Selector="Border.SwitcherBar">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceLow}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="16,8" />
        </Style>
        <!-- The unified outer frame around all three selectors: a dark fill one step
             lighter than the toolbar, a single unobtrusive hairline border, and softly
             rounded corners. ClipToBounds keeps per-segment hover fills inside the radius. -->
        <Style Selector="Border.SwitcherGroup">
            <Setter Property="Background" Value="{DynamicResource AppSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>
        <!-- One selector cell inside the bar (label above its combobox). Roomy padding so
             the contents never feel cramped; hover subtly lifts the whole cell. -->
        <Style Selector="Border.SwitcherSegment">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="14,6,10,7" />
        </Style>
        <Style Selector="Border.SwitcherSegment:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAlt}" />
        </Style>
        <!-- Very fine vertical hairline between two cells, inset top/bottom so it reads as
             a quiet separator rather than a full-height rule. -->
        <Style Selector="Border.SwitcherDivider">
            <Setter Property="Width" Value="1" />
            <Setter Property="Background" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="Margin" Value="0,6" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
        <!-- Small, restrained caption above each selector (DEVICE / PROFILE / WORKSPACE):
             smaller type, tighter tracking, and a slim gap down to its selector. -->
        <Style Selector="TextBlock.SwitcherCaption">
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
            <Setter Property="Margin" Value="1,0,0,1" />
            <Setter Property="LetterSpacing" Value="0.4" />
        </Style>
        <!-- Each selector is chrome-free (the SwitcherGroup provides the frame); it only
             contributes its content and dropdown glyph. Consistent width keeps the cells
             balanced. -->
        <Style Selector="ComboBox.Switcher">
            <Setter Property="MinWidth" Value="180" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="8,0,0,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        </Style>
        <!-- Borderless body; a constant-width bottom edge (transparent by default) becomes a
             fine accent underline when the cell is open/active, avoiding any layout shift. -->
        <Style Selector="ComboBox.Switcher /template/ Border#Background">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>
        <!-- Hover is carried by the segment cell, so the combobox stays transparent here. -->
        <Style Selector="ComboBox.Switcher:pointerover /template/ Border#Background">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
        </Style>
        <!-- Open/active: a subtle accent underline marks the live cell. -->
        <Style Selector="ComboBox.Switcher:pressed /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{DynamicResource PageActiveBorderBrush}" />
        </Style>
        <Style Selector="ComboBox.Switcher:focus /template/ Border#Background">
            <Setter Property="BorderBrush" Value="{DynamicResource PageActiveBorderBrush}" />
        </Style>
        <!-- Selected text stays clearly readable in the primary (light) colour. -->
        <Style Selector="ComboBox.Switcher /template/ ContentControl#ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        </Style>
        <!-- Small, clean, uniform dropdown chevron in a muted colour, held off the right edge. -->
        <Style Selector="ComboBox.Switcher /template/ PathIcon#DropDownGlyph">
            <Setter Property="Width" Value="9" />
            <Setter Property="Height" Value="5" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextSecondary}" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>

        <!-- Dropdown list: match the selectors — same fill, hairline border, soft corners. -->
        <Style Selector="ComboBox.Switcher /template/ Border#PopupBorder">
            <Setter Property="Background" Value="{DynamicResource AppSurface}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderSubtle}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <!-- Airier rows so the list reads calmly; a left accent stripe placeholder is
             filled in on the selected row below. -->
        <Style Selector="ComboBox.Switcher ComboBoxItem">
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinHeight" Value="0" />
        </Style>
        <!-- Hover: a soft neutral lift, clearly distinct from selection. -->
        <Style Selector="ComboBox.Switcher ComboBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppControlBackground}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
        </Style>
        <!-- Selected: a subtle accent tint plus a slim accent stripe on the left, instead
             of a flat, heavy fill. -->
        <Style Selector="ComboBox.Switcher ComboBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppAccentSubtle}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PageActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
        <!-- Selected + hover: the same accent, a touch lighter, keeping the two states apart. -->
        <Style Selector="ComboBox.Switcher ComboBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AppControlBackgroundHover}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextPrimary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PageActiveBorderBrush}" />
            <Setter Property="BorderThickness" Value="3,0,0,0" />
        </Style>
    </Window.Styles>
    <Design.DataContext>
        <vm:MainShellViewModel />
    </Design.DataContext>

    <!-- The hamburger overlays the device cell (rather than sitting in its own column)
         so its right edge lines up with the body's right edge instead of widening the
         window past the device. The body ends at SVG x=825 of the 900-wide viewBox,
         ~63px in from the 760px Viewbox's right edge. -->
    <!-- Focusable so a drag can grab keyboard focus and receive Esc / live Ctrl during the
         gesture (issue #166 phase 3). IsTabStop=False keeps it out of the tab order. -->
    <Grid Name="RootGrid" RowDefinitions="Auto,*" Focusable="True" IsTabStop="False">
        <!-- Device → Profile → Workspace switcher (issue #132). One modern top bar,
             centred, mirroring the original software. The Device selector only appears
             when more than one device is connected (single-device users see just their
             Profile and Workspace). -->
        <Border Grid.Row="0" Classes="SwitcherBar">
            <!-- One framed bar fusing the three selectors into a single context path. Fine
                 vertical hairlines separate the cells; each cell keeps its own label and
                 dropdown. The Device cell (and its trailing divider) only appears when more
                 than one device is connected. -->
            <Border Classes="SwitcherGroup" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <!-- Device -->
                    <Border Classes="SwitcherSegment" IsVisible="{Binding HasMultipleDevices}">
                        <StackPanel>
                            <TextBlock Classes="SwitcherCaption" Text="DEVICE" />
                            <ComboBox Classes="Switcher"
                                      ItemsSource="{Binding Devices}"
                                      SelectedItem="{Binding SelectedDevice}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MainWindowViewModel">
                                        <TextBlock Text="{Binding DeviceName}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Classes="SwitcherDivider" IsVisible="{Binding HasMultipleDevices}" />

                    <!-- Profile -->
                    <Border Classes="SwitcherSegment">
                        <StackPanel>
                            <TextBlock Classes="SwitcherCaption" Text="PROFILE" />
                            <ComboBox Classes="Switcher"
                                      ItemsSource="{Binding SelectedDevice.Profiles}"
                                      SelectedItem="{Binding SelectedDevice.SelectedProfile}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Profile">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <Border Classes="SwitcherDivider" />

                    <!-- Workspace -->
                    <Border Classes="SwitcherSegment">
                        <StackPanel>
                            <TextBlock Classes="SwitcherCaption" Text="WORKSPACE" />
                            <ComboBox Classes="Switcher"
                                      ItemsSource="{Binding SelectedDevice.Workspaces}"
                                      SelectedItem="{Binding SelectedDevice.SelectedWorkspace}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="models:Workspace">
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Border>

        <Grid Grid.Row="1">
            <ContentControl Name="DeviceLayoutHost" Padding="0" />

            <Button VerticalAlignment="Top" HorizontalAlignment="Right"
                VerticalContentAlignment="Center" HorizontalContentAlignment="Center"
                Width="50" Height="50"
                Margin="0,4,63,0"
                Background="Transparent"
                BorderBrush="Transparent"
                BorderThickness="0">
            <!-- Theme-aware hamburger (three bars) so the menu icon follows Light/Dark
                 instead of being a fixed-white SVG that vanishes on a light window. -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="4">
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
                <Rectangle Width="24" Height="2.5" RadiusX="1.25" RadiusY="1.25" Fill="{DynamicResource AppTextPrimary}" />
            </StackPanel>
            <Button.Flyout>
                <Flyout Placement="Left">
                    <StackPanel>
                        <Button Width="100" Height="40" VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Settings"
                                Command="{Binding SelectedDevice.SettingsMenuCommand}" />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center" Margin="0,5,0,0"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Macros"
                                Command="{Binding SelectedDevice.MacroEditorMenuCommand}" />
                        <Separator />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="About"
                                Command="{Binding SelectedDevice.AboutMenuCommand}" />
                        <Button Width="100" Height="40" VerticalContentAlignment="Center" Margin="0,5,0,0"
                                HorizontalContentAlignment="Center"
                                FontSize="18"
                                Content="Quit"
                                Command="{Binding SelectedDevice.QuitApplicationCommand}" />
                    </StackPanel>
                </Flyout>
            </Button.Flyout>
            </Button>
        </Grid>

        <!-- Drag & drop overlay (issue #166 phase 3): a drop-target ring coloured by the pending
             operation (green move / amber swap / blue copy, red invalid) and a slightly
             translucent ghost of the dragged button in its current state with a rounded frame like
             the touch tiles. Non-hit-testable so it never intercepts pointer input. -->
        <Canvas Name="DragOverlay" Grid.Row="0" Grid.RowSpan="2"
                IsHitTestVisible="False" IsVisible="False">
            <Border Name="DropHighlight"
                    IsVisible="False"
                    BorderThickness="3" CornerRadius="6"
                    BorderBrush="#FF3DDB6E" Background="Transparent" />
            <Border Name="DragGhost"
                    IsVisible="False"
                    Opacity="0.7"
                    CornerRadius="6" ClipToBounds="True"
                    BorderThickness="3" BorderBrush="{StaticResource PageActiveBorderBrush}"
                    Background="#FF202020">
                <Image Name="DragGhostImage" Stretch="Fill" />
            </Border>
        </Canvas>
    </Grid>
</Window>
